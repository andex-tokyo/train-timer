<?xml version="1.0" encoding="utf-8"?>
<RelativeLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:id="@+id/widget_root"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@drawable/widget_background"
    android:paddingStart="10dp"
    android:paddingTop="8dp"
    android:paddingEnd="10dp"
    android:paddingBottom="8dp">

    <TextView
        android:id="@+id/widget_station"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginEnd="24dp"
        android:ellipsize="end"
        android:maxLines="1"
        android:text="舞浜"
        android:textColor="#F7F8F8"
        android:textSize="15sp"
        android:textStyle="bold" />

    <TextView
        android:id="@+id/widget_last_train"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_alignParentTop="true"
        android:layout_alignParentEnd="true"
        android:layout_marginTop="18dp"
        android:text="終電"
        android:textColor="#FF6B6B"
        android:textSize="10sp"
        android:textStyle="bold"
        android:visibility="gone" />

    <TextView
        android:id="@+id/widget_direction"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_below="@id/widget_station"
        android:layout_marginTop="1dp"
        android:layout_marginEnd="8dp"
        android:ellipsize="end"
        android:maxLines="1"
        android:text="東京方面"
        android:textColor="#C8CDD2"
        android:textSize="10sp" />

    <TextView
        android:id="@+id/widget_departure"
        android:layout_width="72dp"
        android:layout_height="wrap_content"
        android:layout_alignParentBottom="true"
        android:ellipsize="end"
        android:maxLines="1"
        android:text="08:42"
        android:textColor="#DDE2E5"
        android:textSize="13sp" />

    <TextView
        android:id="@+id/widget_countdown_label"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_above="@id/widget_countdown"
        android:layout_alignEnd="@id/widget_countdown"
        android:layout_marginBottom="-4dp"
        android:text="あと"
        android:textColor="#68E0D2"
        android:textSize="8sp"
        android:textStyle="bold" />

    <TextView
        android:id="@+id/widget_countdown"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_alignParentEnd="true"
        android:layout_alignParentBottom="true"
        android:layout_marginStart="4dp"
        android:layout_toEndOf="@id/widget_departure"
        android:ellipsize="end"
        android:fontFamily="monospace"
        android:gravity="end"
        android:includeFontPadding="false"
        android:maxLines="1"
        android:text="7分"
        android:textColor="#FFFFFF"
        android:textSize="26sp"
        android:textStyle="bold" />

    <Chronometer
        android:id="@+id/widget_chronometer"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_alignParentEnd="true"
        android:layout_alignParentBottom="true"
        android:layout_marginStart="4dp"
        android:layout_toEndOf="@id/widget_departure"
        android:ellipsize="end"
        android:fontFamily="monospace"
        android:gravity="end"
        android:includeFontPadding="false"
        android:maxLines="1"
        android:textColor="#FFFFFF"
        android:textSize="24sp"
        android:textStyle="bold"
        android:visibility="gone" />
</RelativeLayout>
